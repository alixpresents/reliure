{
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "trailingSlash": false,
  "redirects": [
    { "source": "/explorer", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/__spa-fallback.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}