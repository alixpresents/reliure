{
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "rewrites": [
    { "source": "/(.*)", "destination": "/__spa-fallback.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
