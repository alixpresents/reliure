{
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "trailingSlash": false,
  "redirects": [
    { "source": "/explorer", "destination": "/", "permanent": true },
    { "source": "/:path(.*)", "has": [{ "type": "host", "value": "www.reliure.page" }], "destination": "https://reliure.page/:path", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/livre/:slug",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Twitterbot|LinkedInBot|Discordbot|Slackbot|WhatsApp|TelegramBot|Googlebot|bingbot|Applebot|Pinterestbot|redditbot).*" }],
      "destination": "/api/og?type=book&slug=:slug"
    },
    {
      "source": "/selections/:slug",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Twitterbot|LinkedInBot|Discordbot|Slackbot|WhatsApp|TelegramBot|Googlebot|bingbot|Applebot|Pinterestbot|redditbot).*" }],
      "destination": "/api/og?type=selection&slug=:slug"
    },
    { "source": "/(.*)", "destination": "/__spa-fallback.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}